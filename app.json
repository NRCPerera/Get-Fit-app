{
  "expo": {
    "name": "GetFit",
    "slug": "gym-management-app",
    "version": "1.2.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "getfit",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ridma2001.getfit",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "GetFit needs access to your camera to allow you to take profile pictures or scan gym equipment.",
        "NSPhotoLibraryUsageDescription": "GetFit needs access to your photos to let you upload a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.getfit.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GetFit to access your camera."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GetFit to access your photos."
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#6366f1",
          "sounds": []
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "90a966f6-cf24-4333-831a-c48108ee0a91"
      }
    },
    "owner": "ridma2001"
  }
}
